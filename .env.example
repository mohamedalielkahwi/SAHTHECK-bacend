# Application Configuration
NODE_ENV=development
APP_PORT=3000

# Database Configuration
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=nestjs_server
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_TEST_NAME=nestjs_server_test
DATABASE_URL=postgresql://postgres:password@localhost:5432/nestjs_server

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=uploads
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=http://localhost:9000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_EXPIRATION=7d

# Email Configuration (MailDev for development)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=false
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@yourapp.com
MAIL_DEFAULT_NAME=Your App
MAIL_CLIENT_PORT=1080

# Adminer Database UI
ADMINER_PORT=8080

# Swagger API Documentation
SWAGGER_USERNAME=swagger
SWAGGER_PASSWORD=swagger-pass

# OTP Configuration (if using SMS/WhatsApp auth)
OTP_LENGTH=4
OTP_EXPIRY=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_DAY=3
OTP_RATE_LIMIT_PER_HOUR=3
OTP_RESEND_COOLDOWN=60
OTP_ABUSE_CONSECUTIVE_REQUESTS=3
OTP_ABUSE_WAIT_SECONDS=300

# Twilio Configuration (for SMS/WhatsApp - optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
SMS_DRY_RUN=true
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Facebook WhatsApp API Configuration (optional)
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PHONE_NUMBER_ID=your_phone_number_id
FACEBOOK_TEMPLATE_NAME=your_template_name

# Production Admin Configuration
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=YourSecurePassword123
ADMIN_NAME=Super Administrator

# Logging
LOG_RETENTION_DAYS=90