// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  TWO_FACTOR
}

enum Type {
  pdf
  image
}

enum Status {
  SCHEDULED
  ACEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum Category {
  IRM
  scanner
  radioStandard
  echographie
  bilanKene
  protocoleDeReEducation
  resultatsDAnalyse
}

enum Title {
  radiography
  prescription
  physieotherapy
  bilanBiologique
}

enum PostType {
  ARTICLE
  VIDEO
  IMAGE
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model User {
  userId          String      @id @default(uuid())
  fullName        String?
  email           String      @unique
  password        String?
  phone           String?
  imageUrl        String?
  isEmailVerified Boolean     @default(false)
  gender          Gender?
  role            Role
  address         String?
  isGoogleAccount Boolean     @default(false)
  createdAt       DateTime    @default(now())
  otps            Otp[]
  patient         Patient?
  specialist      Specialist?
  admin           Admin?
  messages        Message[]
}

model Conversation {
  conversationId String       @id @default(uuid())
  patientId      String
  specialistId   String
  appointmentId  String?      @unique
  createdAt      DateTime     @default(now())
  patient        Patient      @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  specialist     Specialist   @relation(fields: [specialistId], references: [userId], onDelete: Cascade)
  appointment    Appointment? @relation(fields: [appointmentId], references: [appointmentId], onDelete: SetNull)
  messages       Message[]
}

model Message {
  messageId      String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [conversationId], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [userId], onDelete: Cascade)
}

model Patient {
  userId            String            @id
  age               Int?
  weight            Float?
  height            Float?
  exerciseTolerance String?
  exercises         Exercise[]
  user              User              @relation(fields: [userId], references: [userId], onDelete: Cascade)
  medicalHistory    MedicalDocument[]
  appointments      Appointment[]
  conversations     Conversation[]
}

model MedicalDocument {
  id          String   @id @default(uuid())
  userId      String
  title       Title
  date        DateTime
  type        Type
  category    Category
  description String?
  fileUrl     String
  uploadedAt  DateTime @default(now())
  patient     Patient  @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Specialist {
  userId         String         @id
  speciality     String?
  bio            String?
  licenseNumber  String
  isValidated    Boolean        @default(false)
  clinic         String?
  location       String?
  rating         Float          @default(0)
  reviewsCount   Int            @default(0)
  latitude       Float?
  longitude      Float?
  user           User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  clinics        Clinic[]
  appointments   Appointment[]
  posts          Post[]
  exercises      Exercise[]
  conversations  Conversation[]
  availableSlots AvailabeSlot[]
}

model Admin {
  userId      String  @id
  canModerate Boolean @default(false)
  user        User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Clinic {
  clinicId     String        @id @default(uuid())
  name         String
  address      String
  phone        String
  email        String
  specialists  Specialist[]
  appointments Appointment[]
}

model AvailabeSlot {
  availabilityId String       @id @default(uuid())
  specialistId   String
  startTime      DateTime
  endTime        DateTime
  date           DateTime
  place          String
  isBooked       Boolean      @default(false)
  specialist     Specialist   @relation(fields: [specialistId], references: [userId], onDelete: Cascade)
  appointments   Appointment?
}

model Appointment {
  appointmentId  String        @id @default(uuid())
  patientId      String?
  specialistId   String
  clinicId       String?
  availabilityId String        @unique
  reason         String
  status         Status        @default(SCHEDULED)
  createdAt      DateTime      @default(now())
  patient        Patient?      @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  specialist     Specialist    @relation(fields: [specialistId], references: [userId], onDelete: Cascade)
  clinic         Clinic?       @relation(fields: [clinicId], references: [clinicId], onDelete: Cascade)
  AvailableSlot  AvailabeSlot  @relation(fields: [availabilityId], references: [availabilityId], onDelete: Cascade)
  conversation   Conversation?
}

model Post {
  postId        String     @id @default(uuid())
  title         String
  description   String
  type          PostType
  url           String?
  publishedById String
  isPublished   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  specialist    Specialist @relation(fields: [publishedById], references: [userId], onDelete: Cascade)
}

model Exercise {
  exerciseId   String     @id @default(uuid())
  name         String
  description  String
  videoUrl     String?
  createdById  String
  isPublic     Boolean    @default(false)
  assignedToId String?
  createdAt    DateTime   @default(now())
  patient      Patient?   @relation(fields: [assignedToId], references: [userId])
  specialist   Specialist @relation(fields: [createdById], references: [userId], onDelete: Cascade)
}
