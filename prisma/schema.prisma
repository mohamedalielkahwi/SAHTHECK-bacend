// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  TWO_FACTOR
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model User{
  userId        String      @id @default(uuid())
  fullName      String?
  email     String   @unique
  password  String?
  phone String?
  imageUrl String?
  isEmailVerified Boolean @default(false)
  otps            Otp[]
  gender Gender?
  role Role
  address String?
  patient Patient?
  specialist Specialist?
  admin Admin?
  createdAt DateTime @default(now())
}

model Patient {
  userId        String      @id
  age Int?
  weight Float?
  height Float?
  medicalHistory MedicalDocument[]
  user User @relation(fields: [userId], references: [userId],onDelete: Cascade)
}

enum Category {
  pdf
  image
}

model MedicalDocument{
  userId String
  id String @id @default(uuid())
  title String
  date DateTime
  type Category
  category String
  fileUrl String
  uploadedAt DateTime @default(now())
  patient Patient @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Specialist {
  userId        String  @id
  speciality    String?
  bio           String?
  licenseNumber String
  isValidated   Boolean @default(false)
  clinic        String?
  location      String?
  rating        Float   @default(0)
  reviewsCount  Int     @default(0)
  latitude      Float?
  longitude     Float?
  user          User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Admin {
  userId        String      @id
  canModerate Boolean @default(false)
  user User @relation(fields: [userId], references: [userId],onDelete: Cascade)
}