// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  TWO_FACTOR
}

enum Type {
  pdf
  image
}

enum Status {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum Category{
  IRM
}

enum Title{
  radiography
  prescription
  bilanKine
  analyseDuSang
}
enum PostType {
  ARTICLE
  VIDEO
  IMAGE
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model User {
  userId          String      @id @default(uuid())
  fullName        String?
  email           String      @unique
  password        String?
  phone           String?
  imageUrl        String?
  isEmailVerified Boolean     @default(false)
  gender          Gender?
  role            Role
  address         String?
  createdAt       DateTime    @default(now())
  otps            Otp[]
  patient         Patient?
  specialist      Specialist?
  admin           Admin?
}

model Patient {
  userId         String            @id
  age            Int?
  weight         Float?
  height         Float?
  user           User              @relation(fields: [userId], references: [userId], onDelete: Cascade)
  medicalHistory MedicalDocument[]
  appointments   Appointment[]
}

model MedicalDocument {
  id         String   @id @default(uuid())
  userId     String
  title      Title
  date       DateTime
  type       Type
  category   Category
  fileUrl    String
  uploadedAt DateTime @default(now())
  patient    Patient  @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Specialist {
  userId        String        @id
  speciality    String?
  bio           String?
  licenseNumber String
  isValidated   Boolean       @default(false)
  clinic        String?
  location      String?
  rating        Float         @default(0)
  reviewsCount  Int           @default(0)
  latitude      Float?
  longitude     Float?
  user          User          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  clinics       Clinic[]
  appointments  Appointment[]
  posts      Post[]
  exercises     Exercise[]
}

model Admin {
  userId      String  @id
  canModerate Boolean @default(false)
  user        User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Clinic {
  clinicId     String        @id @default(uuid())
  name         String
  address      String
  phone        String
  email        String
  specialists  Specialist[]
  appointments Appointment[]
}

model AvailabeSlot {
  availabilityId String        @id @default(uuid())
  startTime      DateTime
  endTime        DateTime
  date           DateTime
  isBooked       Boolean       @default(false)
  appointments   Appointment[]
}

model Appointment {
  appointmentId  String       @id @default(uuid())
  patientId      String?
  specialistId   String
  clinicId       String?
  availabilityId String
  date           DateTime @db.Date
  time           DateTime @db.Time(6)
  reason         String
  status         Status       @default(SCHEDULED)
  patient        Patient?      @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  specialist     Specialist   @relation(fields: [specialistId], references: [userId], onDelete: Cascade)
  clinic         Clinic?      @relation(fields: [clinicId], references: [clinicId], onDelete: Cascade)
  AvailableSlot  AvailabeSlot @relation(fields: [availabilityId], references: [availabilityId], onDelete: Cascade)
}

model Post {
  postId     String      @id @default(uuid())
  title         String
  description   String
  type          PostType
  url           String?
  publishedById String
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  specialist    Specialist  @relation(fields: [publishedById], references: [userId], onDelete: Cascade)
}

model Exercise {
  exerciseId  String     @id @default(uuid())
  name        String
  description String
  videoUrl    String?
  createdById String
  createdAt   DateTime   @default(now())
  specialist  Specialist @relation(fields: [createdById], references: [userId], onDelete: Cascade)
}
